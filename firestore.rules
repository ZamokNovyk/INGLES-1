rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
             request.auth.token.email == "wikistars12@gmail.com" &&
             request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.]+$');
    }

    function isValidNewStudent(data) {
      return data.nombre is string && data.nombre.size() > 0 && data.nombre.size() <= 120 &&
             data.get('género', '') is string && (data.get('género', '') == "hombres" || data.get('género', '') == "mujeres") &&
             data.elo is number &&
             data.votos_ganados is number &&
             data.votos_perdidos is number;
    }

    function isValidConfig(data) {
      return data.id is string &&
             data.isActive is bool;
    }

    // 2. Collection Rules: Students
    match /{collectionName}/generos/{generoId}/{studentId} {
      allow read: if collectionName == "INGLES1.Estudiantes";
      
      // Allow any user to create a student (with schema validation) to support startup seeding
      allow create: if collectionName == "INGLES1.Estudiantes" && isValidId(studentId) && (generoId == "hombres" || generoId == "mujeres") && isValidNewStudent(request.resource.data);
      // Only Admin can delete profiles
      allow delete: if collectionName == "INGLES1.Estudiantes" && isAdmin() && isValidId(studentId);
      
      allow update: if collectionName == "INGLES1.Estudiantes" && ((isAdmin() && isValidNewStudent(request.resource.data)) || (
        // Non-admin can ONLY modify 'elo', 'votos_ganados', 'votos_perdidos', and 'actualizadoEn'
        // This is the Tiered Identity / Action-Based Update Pattern (Pillars 4 & 5)
        isValidId(studentId) &&
        isValidNewStudent(request.resource.data) &&
        request.resource.data.nombre == resource.data.nombre &&
        request.resource.data.get('género', '') == resource.data.get('género', '') &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['elo', 'votos_ganados', 'votos_perdidos', 'actualizadoEn'])
      ));
    }

    // 3. Collection Rules: System Config
    match /config/{configId} {
      allow read: if true;
      // Allow creation of static config (important for fallback fallback bootstrapping on empty DBs)
      allow create: if isValidId(configId) && isValidConfig(request.resource.data);
      // Only Admin can modify or delete existing configs
      allow update: if isAdmin() && isValidId(configId) && isValidConfig(request.resource.data);
      allow delete: if isAdmin() && isValidId(configId);
    }
  }
}
